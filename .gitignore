# ========================================
# TERRAFORM CORE
# ========================================

# State files (anywhere)
**/*.tfstate
**/*.tfstate.*
**/*.tfstate.backup
**/crash.log
**/crash.*.log

# Local directories and plugins
**/.terraform/
**/.terraform.lock.hcl

# CLI config
.terraformrc
terraform.rc

# ========================================
# SECURITY & CREDENTIALS
# ========================================

# Sensitive file extensions (anywhere)
*.pem
*.key

# Specific sensitive config files
provider.tf
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ========================================
# EXCEPTIONS (Keep Structure)
# ========================================

# Keep directory markers (but not the files themselves if they are empty)
!**/.gitkeep